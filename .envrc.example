# BeyondTrust Terraform Provider - Development Environment
#
# This file contains environment variables needed for local development and testing.
#
# Setup Instructions:
#   1. Install direnv: brew install direnv
#   2. Copy this file: cp .envrc.example .envrc
#   3. Edit .envrc with your credentials
#   4. Enable direnv: direnv allow
#   5. Environment variables will auto-load when you cd into this directory
#
# For CI/CD: Configure these same variables as GitHub Secrets

# Required: BeyondTrust Workload Credentials API Configuration
export BEYONDTRUST_API_URL="https://api.beyondtrust.io"
export BEYONDTRUST_ACCESS_TOKEN="your-access-token-here"
export BEYONDTRUST_SITE_ID="your-site-uuid"

# Required for Workload Identity (auth) acceptance tests — these manage resources
# against the org's ADMIN site, which has its own dedicated credentials (a token is
# scoped to a single site). When unset, the workload-identity acceptance tests are skipped.
export BEYONDTRUST_ADMIN_SITE_ID="your-admin-site-uuid"
export BEYONDTRUST_ADMIN_ACCESS_TOKEN="your-admin-site-access-token"

# Required for AWS Integration Tests
export BEYONDTRUST_TEST_AWS_ROLE_ARN="arn:aws:iam::123456789012:role/staging-test-role"
export BEYONDTRUST_TEST_AWS_ROLE_ARN_2="arn:aws:iam::123456789012:role/second-staging-test-role"
export BEYONDTRUST_TEST_AWS_TARGET_ROLE_ARN="arn:aws:iam::123456789012:role/staging-target-role"

# Required for Azure Integration Tests
# tenant_id: Azure AD directory (tenant) UUID
# client_id: Application (client) ID of the service principal used as the integration identity
# client_secret: That service principal's client secret
# application_object_id: Object ID (NOT client ID) of a target app registration whose passwords will be generated
export BEYONDTRUST_TEST_AZURE_TENANT_ID="your-azure-tenant-uuid"
export BEYONDTRUST_TEST_AZURE_CLIENT_ID="service-principal-client-id-uuid"
export BEYONDTRUST_TEST_AZURE_CLIENT_SECRET="service-principal-client-secret"
export BEYONDTRUST_TEST_AZURE_APPLICATION_OBJECT_ID="target-app-object-id-uuid"

# Optional: Override API version (defaults to 2026-04-28)
# export BEYONDTRUST_API_VERSION="2026-04-28"