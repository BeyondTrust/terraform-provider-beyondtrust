# Complete example: Folder → AWS Integration → Dynamic Secret

# Step 1: Create folder hierarchy
resource "beyondtrust_secrets_folder" "production" {
  name   = "production"
  folder = ""

  tags = {
    environment = "production"
    managed_by  = "terraform"
  }
}

resource "beyondtrust_secrets_folder" "aws" {
  name   = "aws"
  folder = beyondtrust_secrets_folder.production.path

  tags = {
    purpose = "aws-credentials"
  }
}

# Step 2: Create AWS integration
resource "beyondtrust_secrets_aws_integration" "prod_account" {
  name        = "prod-aws-account"
  role_arn    = var.integration_role_arn
  external_id = var.external_id
}

# Step 3: Create dynamic secret for developers
resource "beyondtrust_secrets_aws_dynamic_secret" "developer_access" {
  name             = "developer-assume-role"
  folder           = beyondtrust_secrets_folder.aws.path
  integration_name = beyondtrust_secrets_aws_integration.prod_account.name

  credential_type = "assumed_role"
  role_arn        = var.developer_role_arn
  ttl             = 3600 # 1 hour

  policy_arns = [
    "arn:aws:iam::aws:policy/ReadOnlyAccess"
  ]

  # Optional: Additional inline policy
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = "*"
      }
    ]
  })

  # Optional: AWS session tags
  aws_tags = {
    Environment = "Production"
    ManagedBy   = "Terraform"
    Team        = "Engineering"
  }
}

# Step 4: Create another dynamic secret for admins
resource "beyondtrust_secrets_aws_dynamic_secret" "admin_access" {
  name             = "admin-assume-role"
  folder           = beyondtrust_secrets_folder.aws.path
  integration_name = beyondtrust_secrets_aws_integration.prod_account.name

  credential_type = "assumed_role"
  role_arn        = var.admin_role_arn
  external_id     = var.admin_external_id # Optional external ID for role
  ttl             = 1800                  # 30 minutes (shorter for admin)

  # Admins get more permissions via managed policies
  policy_arns = [
    "arn:aws:iam::aws:policy/PowerUserAccess"
  ]

  aws_tags = {
    Environment = "Production"
    ManagedBy   = "Terraform"
    Team        = "Platform"
    AccessLevel = "Admin"
  }
}

# Outputs
output "folder_structure" {
  description = "Created folder paths"
  value = {
    production = beyondtrust_secrets_folder.production.path
    aws        = beyondtrust_secrets_folder.aws.path
  }
}

output "integration" {
  description = "AWS integration details"
  value = {
    id   = beyondtrust_secrets_aws_integration.prod_account.id
    name = beyondtrust_secrets_aws_integration.prod_account.name
    arn  = beyondtrust_secrets_aws_integration.prod_account.role_arn
  }
}

output "dynamic_secrets" {
  description = "Dynamic secret paths"
  value = {
    developer = beyondtrust_secrets_aws_dynamic_secret.developer_access.path
    admin     = beyondtrust_secrets_aws_dynamic_secret.admin_access.path
  }
}

output "developer_secret_id" {
  description = "Developer dynamic secret UUID"
  value       = beyondtrust_secrets_aws_dynamic_secret.developer_access.id
}

output "admin_secret_id" {
  description = "Admin dynamic secret UUID"
  value       = beyondtrust_secrets_aws_dynamic_secret.admin_access.id
}
