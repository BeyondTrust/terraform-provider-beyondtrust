# Test AWS integration resource

resource "beyondtrust_secrets_aws_integration" "test" {
  name        = "terraform-test-aws"
  role_arn    = "arn:aws:iam::123456789012:role/beyondtrust/btp-account-role-123456789012"
  external_id = "test-external-id-12345"
}

# Test data source - read the integration we just created
data "beyondtrust_secrets_aws_integration" "test" {
  name = beyondtrust_secrets_aws_integration.test.name
}

output "integration_id" {
  value = beyondtrust_secrets_aws_integration.test.id
}

output "integration_role_arn" {
  value = beyondtrust_secrets_aws_integration.test.role_arn
}

output "data_source_id" {
  value       = data.beyondtrust_secrets_aws_integration.test.id
  description = "ID from data source should match resource ID"
}
