// Example Terratest integration test (rename to .go to use)
package test

import (
	"fmt"
	"os"
	"testing"
	"time"

	"github.com/gruntwork-io/terratest/modules/random"
	"github.com/gruntwork-io/terratest/modules/terraform"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestFolderBasic(t *testing.T) {
	t.Parallel()

	// Generate unique folder name
	uniqueID := random.UniqueId()
	folderName := fmt.Sprintf("terratest-%s", uniqueID)

	terraformOptions := terraform.WithDefaultRetryableErrors(t, &terraform.Options{
		TerraformDir: "./fixtures/folder",
		Vars: map[string]interface{}{
			"folder_name": folderName,
		},
		EnvVars: map[string]string{
			"TF_CLI_CONFIG_FILE": os.Getenv("HOME") + "/.terraformrc",
		},
	})

	// Clean up at the end
	defer terraform.Destroy(t, terraformOptions)

	// Run terraform init and apply
	terraform.InitAndApply(t, terraformOptions)

	// Validate outputs
	folderId := terraform.Output(t, terraformOptions, "folder_id")
	folderPath := terraform.Output(t, terraformOptions, "folder_path")

	assert.NotEmpty(t, folderId, "Folder ID should not be empty")
	assert.Equal(t, folderName, folderPath, "Folder path should match folder name")

	// Test idempotency - apply again, should have no changes
	output := terraform.Apply(t, terraformOptions)
	assert.Contains(t, output, "No changes", "Second apply should have no changes")
}

func TestFolderWithTags(t *testing.T) {
	t.Parallel()

	uniqueID := random.UniqueId()
	folderName := fmt.Sprintf("terratest-tags-%s", uniqueID)

	terraformOptions := terraform.WithDefaultRetryableErrors(t, &terraform.Options{
		TerraformDir: "./fixtures/folder_with_tags",
		Vars: map[string]interface{}{
			"folder_name": folderName,
			"tags": map[string]string{
				"environment": "test",
				"managed_by":  "terratest",
			},
		},
	})

	defer terraform.Destroy(t, terraformOptions)

	terraform.InitAndApply(t, terraformOptions)

	// Validate folder was created with tags
	folderId := terraform.Output(t, terraformOptions, "folder_id")
	require.NotEmpty(t, folderId)
}

func TestFolderHierarchy(t *testing.T) {
	t.Parallel()

	uniqueID := random.UniqueId()
	parentFolder := fmt.Sprintf("parent-%s", uniqueID)
	childFolder := fmt.Sprintf("child-%s", uniqueID)

	terraformOptions := terraform.WithDefaultRetryableErrors(t, &terraform.Options{
		TerraformDir: "./fixtures/folder_hierarchy",
		Vars: map[string]interface{}{
			"parent_folder_name": parentFolder,
			"child_folder_name":  childFolder,
		},
	})

	defer terraform.Destroy(t, terraformOptions)

	terraform.InitAndApply(t, terraformOptions)

	// Validate hierarchy
	parentPath := terraform.Output(t, terraformOptions, "parent_path")
	childPath := terraform.Output(t, terraformOptions, "child_path")

	assert.Equal(t, parentFolder, parentPath)
	assert.Equal(t, fmt.Sprintf("%s/%s", parentFolder, childFolder), childPath)
}

func TestFolderImport(t *testing.T) {
	t.Parallel()

	uniqueID := random.UniqueId()
	folderName := fmt.Sprintf("terratest-import-%s", uniqueID)

	terraformOptions := terraform.WithDefaultRetryableErrors(t, &terraform.Options{
		TerraformDir: "./fixtures/folder",
		Vars: map[string]interface{}{
			"folder_name": folderName,
		},
	})

	defer terraform.Destroy(t, terraformOptions)

	// Create the folder
	terraform.InitAndApply(t, terraformOptions)

	// Get the folder path for import
	folderPath := terraform.Output(t, terraformOptions, "folder_path")

	// Remove from state
	terraform.RunTerraformCommand(t, terraformOptions, "state", "rm", "beyondtrust_secrets_folder.test")

	// Import it back
	terraform.RunTerraformCommand(t, terraformOptions, "import",
		"beyondtrust_secrets_folder.test",
		folderPath)

	// Verify no changes needed
	planOutput := terraform.Plan(t, terraformOptions)
	assert.Contains(t, planOutput, "No changes", "After import, plan should show no changes")
}

func TestFolderUpdate(t *testing.T) {
	t.Parallel()

	uniqueID := random.UniqueId()
	folderName := fmt.Sprintf("terratest-update-%s", uniqueID)

	terraformOptions := terraform.WithDefaultRetryableErrors(t, &terraform.Options{
		TerraformDir: "./fixtures/folder_with_tags",
		Vars: map[string]interface{}{
			"folder_name": folderName,
			"tags": map[string]string{
				"environment": "test",
			},
		},
	})

	defer terraform.Destroy(t, terraformOptions)

	// Initial apply
	terraform.InitAndApply(t, terraformOptions)

	// Update tags
	terraformOptions.Vars["tags"] = map[string]string{
		"environment": "production",
		"updated_at":  time.Now().Format(time.RFC3339),
	}

	// Apply update
	terraform.Apply(t, terraformOptions)

	// Verify folder still exists with same ID
	folderId := terraform.Output(t, terraformOptions, "folder_id")
	assert.NotEmpty(t, folderId)
}
